{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@apolia/domain/*": ["packages/domain/src/*"],
      "@apolia/db/*": ["packages/db/src/*"],
      "@apolia/ui/*": ["packages/ui/src/*"],
      "@apolia/config/*": ["packages/config/*"]
    }
  }
}
